# API Keys (use free tiers when possible)
OPENAI_API_KEY=your_api_key
GROQ_API_KEY=your_api_key
HUGGINGFACE_API_KEY=your_api_key

# Model Configuration
PRIMARY_VLM_MODEL=qwen-vl  # or gemini-pro-vision, gpt-4-vision-preview
VISION_MODEL_API_BASE=https://api.openrouter.ai/v1  # For Qwen
LLM_MODEL_FOR_CLEANSING=llama-3.1-8b-instant  # Groq free tier model

# OCR Fallback
OCR_ENGINE=tesseract  # or easyocr, paddleocr
TESSERACT_PATH=/usr/bin/tesseract

# Application Settings
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=[".pdf",".png",".jpg",".jpeg",".tiff",".txt",".eml"]
TEMP_DIR=./temp_uploads
LOG_LEVEL=INFO

# API Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=60

# Cache Settings
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600